// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "bindings": {
      "cmd-shift-o": null,
      "cmd-m": null
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-t": null,
      "cmd-p": null,
      "cmd-shift-e": null,
      "cmd-shift-d": null,
      "ctrl-shift-g": null,
      "cmd-shift-b": null,
      "cmd-r": null,
      "cmd-?": null,
      "\\ \\": "task::Spawn",
      "cmd-1": "project_panel::ToggleFocus",
      "cmd-alt-;": null,
      "cmd-alt-j": null,
      "cmd-shift-p": "multi_workspace::ToggleWorkspaceSidebar",
      "alt-1": "project_panel::ToggleFocus",
      "cmd-2": "agent::ToggleFocus",
      "alt-2": "agent::ToggleFocus",
      "cmd-3": "terminal_panel::ToggleFocus",
      "alt-3": "terminal_panel::ToggleFocus",
      "cmd-4": null,
      "alt-4": null,
      "z g f": "file_finder::Toggle",
      "z g s": "project_symbols::Toggle"
    }
  },
  {
    "context": "ImageViewer",
    "use_key_equivalents": false,
    "bindings": {
      "=": "image_viewer::ZoomIn",
      "+": "image_viewer::ZoomIn",
      "-": "image_viewer::ZoomOut",
      "0": "image_viewer::ResetZoom",
      "9": "image_viewer::FitToView",
      "1": "image_viewer::ZoomToActualSize",
      "cmd-=": null,
      "cmd-+": null,
      "cmd--": null,
      "cmd-0": null,
      "cmd-1": null,
      "cmd-shift-0": null
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "cmd-d": null,
      "cmd-1": "workspace::ToggleRightDock",
      "alt-1": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "AgentDiff",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-y": null,
      "cmd-alt-y": null,
      "cmd-alt-z": null,
      "cmd-r": "agent::Reject",
      "shift-alt-y": null,
      "shift-alt-z": null,
      "cmd-shift-r": "agent::RejectAll",
    },
  },
  {
    "context": "AgentPanel",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-2": "workspace::ToggleRightDock",
      "alt-2": "workspace::ToggleRightDock",
      "cmd-alt-e": null,
      "cmd-shift-n": "agent::NewThread",
      "cmd-alt-n": null,
      "cmd-alt-c": null,
      "cmd-alt-l": null,
      "cmd-alt-p": null,
      "cmd-shift-j": "agent::ToggleProfileSelector",
      "shift-tab": null,
      "cmd-alt-/": null,
      "alt-tab": null,
      "cmd-shift-j": null,
      "cmd-alt-m": null,
      "cmd-alt-shift-n": null,
      "shift-alt-escape": null,
      "cmd->": null,
      "cmd-shift-e": null,
      "cmd-shift-enter": null,
      "cmd-y": null,
      "cmd-k": "agent::AllowOnce",
      "cmd-shift-a": "agent::AllowAlways",
      "cmd-alt-a": null,
      "cmd-r": "agent::RejectOnce",
      "g d": "agent::OpenAgentDiff",
      "cmd-shift-k": "agent::KeepAll",
      "cmd-shift-r": "agent::RejectAll",
      "ctrl-cmd-m": "agent::CycleFavoriteModels",
    },
  },
  {
    "context": "Editor && editor_agent_diff",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-k": "agent::Keep",
      "cmd-r": "agent::Reject",
      "cmd-shift-k": "agent::KeepAll",
      "cmd-shift-r": "agent::RejectAll",
      "cmd-shift-d": "agent::OpenAgentDiff",
    },
  },
  {
    "context": "AgentDiff",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-r": "agent::Reject",
      "cmd-shift-k": "agent::KeepAll",
      "cmd-shift-r": "agent::RejectAll",
      "cmd-shift-d": "agent::OpenAgentDiff",
    },
  },
  {
    "context": "AcpThread > Editor",
    "use_key_equivalents": true,
    "bindings": {
      "shift-ctrl-r": "agent::OpenAgentDiff",
      "shift-ctrl-d": "git::Diff",
      "shift-alt-y": null,
      "shift-alt-z": null,
      "cmd-shift-k": "agent::KeepAll",
      "cmd-shift-r": "agent::RejectAll",
      "shift-alt-u": "agent::UndoLastReject",
      "cmd-enter": "agent::ChatWithFollow",
      "cmd-shift-enter": "agent::SendImmediately",
      "cmd-shift-alt-enter": "agent::SendNextQueuedMessage",
      "cmd-shift-backspace": "agent::RemoveFirstQueuedMessage",
      "cmd-ctrl-e": "agent::EditFirstQueuedMessage",
      "cmd-alt-backspace": "agent::ClearMessageQueue",
      "cmd-shift-v": "agent::PasteRaw",
      "cmd-i": "agent::ToggleProfileSelector",
      "ctrl-;": "agent::OpenAddContextMenu",
      "cmd-alt-'": "agent::ToggleThinkingEffortMenu",
      "ctrl-'": "agent::CycleThinkingEffort",
      "ctrl-alt-up": null,
      "ctrl-alt-down": null,
      "shift-k": "agent::ScrollOutputLineUp",
      "shift-j": "agent::ScrollOutputLineDown"
    },
  },
  {

  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-tab": "pane::ActivateNextItem",
      "ctrl-shift-tab": "pane::ActivatePreviousItem"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-shift-i": null,
      "shift shift": "assistant::InlineAssist",
      "ctrl-space": "editor::ShowCompletions"
    }
  },
  {
    "context": "Editor && vim_mode==normal",
    "bindings": {
      "z g p": "editor::GoToDiagnostic",
      "z p": "editor::ToggleInlineDiagnostics",
      "[ m": "vim::PreviousMethodStart",
      "] m": "vim::NextMethodStart",
      "[ h": "editor::GoToPreviousHunk",
      "] h": "editor::GoToHunk",
      "[ c": "editor::GoToPreviousChange",
      "] c": "editor::GoToNextChange",
      "z r r": "editor::Rename",
      // commands start with z-z are dummy commands that should be chained via "workspace::SendKeystrokes"
      "z z r f": "editor::Format",
      "z r f": ["workspace::SendKeystrokes", "z z r f enter"]
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "g space": null,
      "z r f i x": "editor::ToggleCodeActions",
      "z r e p l": "repl::Run",
      "g .": null,
      "g d": "editor::GoToDeclaration",
      "g r": "editor::FindAllReferences",
      "shift-enter": "editor::OpenExcerptsSplit",
      "ctrl-enter": "editor::OpenExcerpts",
      "ctrl-c": "vim::SwitchToNormalMode"
    }
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "z shift-c": null,
      "z g g": "outline::Toggle",
      "z f f": "editor::ToggleFold",
      "z f r": "editor::ToggleFoldRecursive",
      "z u u": "editor::UnfoldLines",
      "z u r": "editor::UnfoldRecursive",
      "z f a": "editor::FoldAll",
      "z u a": "editor::UnfoldAll",
      "z f d": "editor::ToggleSelectedDiffHunks"
    }
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "z f": "editor::FoldSelectedRanges"
      // "j k": "vim::NormalBefore" // In insert mode, make jk escape to normal mode.
    }
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "ctrl-l": "editor::ShowEditPrediction",
      "ctrl-k": "editor::ShowCompletions",
      "ctrl-x ctrl-o": null,
      "ctrl-x ctrl-c": null
    }
  },
  {
    "context": "Editor && jupyter && !ContextEditor",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-shift-enter": null,
      "ctrl-alt-enter": null,
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "o": "project_panel::OpenPermanent"
    }
  },
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      // Put key bindings here (in addition to the context above) if you want them to
      // work when no editor exists.
      // "space f": "file_finder::Toggle"
    }
  },
  {
    "context": "AgentConfiguration",
      "bindings": {
        "backspace": "pane::GoBack",
        "escape": "pane::GoBack"
      }
  },
  {
    "context": "Editor && edit_prediction",
    "bindings": {
      "ctrl-l": "editor::AcceptNextWordEditPrediction",
      "ctrl-j": "editor::AcceptNextLineEditPrediction",
      "ctrl-enter": "editor::AcceptEditPrediction",
    }
  },
  {
    "context": "Editor && jupyter && !ContextEditor",
    "bindings": {
      "z r e": "repl::Run"
    }
  },
  {
    "context": "Editor && jupyter && !ContextEditor",
    "unbind": {
      "ctrl-shift-enter": "repl::Run"
    }
  },
  {
    "context": "Editor && jupyter && !ContextEditor",
    "bindings": {
      "z r e": "repl::Run"
    }
  },
  {
    "context": "Editor && jupyter && !ContextEditor",
    "unbind": {
      "ctrl-shift-enter": "repl::Run"
    }
  },
  {
    "context": "Editor && jupyter && !ContextEditor",
    "bindings": {
      "cmd-enter": "repl::Run"
    }
  },
  {
    "context": "Editor && jupyter && !ContextEditor",
    "unbind": {
      "ctrl-shift-enter": "repl::Run"
    }
  },
  {
    "context": "AcpThread > Editor",
    "bindings": {
      "cmd-shift-m": "agent::CycleModeSelector"
    }
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "shift-tab": "agent::CycleModeSelector"
    }
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "alt-cmd-.": "agent::ToggleFastMode"
    }
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "alt-cmd-k": "agent::ToggleThinkingMode"
    }
  },
  {
    "context": "InlineAssistant > Editor",
    "unbind": {
      "alt-tab": "agent::CycleFavoriteModels"
    }
  },
  {
    "context": "InlineAssistant > Editor",
    "unbind": {
      "alt-cmd-/": "agent::ToggleModelSelector"
    }
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "alt-tab": "agent::CycleFavoriteModels"
    }
  }
]
