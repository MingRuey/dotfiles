// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": [
          "default"
        ]
      },
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "show_edit_predictions": true,
  "debugger": {
    "dock": "right"
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6-latest",
        "enable_thinking": false
      }
    ],
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "write_file": { "default": "confirm" },
        "edit_file": { "default": "confirm" },
        "delete_file": { "default": "confirm" }
      },
    },
    "notify_when_agent_waiting": "never",
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest"
    },
    "model_parameters": [],
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest"
    }
  },
  "languages": {
    "Python": {"show_edit_predictions": true,
               "language_servers": ["ruff"]}
  },
  "file_types": {
    "C++": ["tpp"]
  },
  "ssh_connections": [
    {
      "host": "122.116.105.200",
      "username": "mrchou",
      "args": [
        "-i",
        "~/.ssh/id_remote"
      ],
      "projects": [
        {
          "paths": [
            "/home/mrchou/code/agent-skills"
          ]
        },
        {
          "paths": [
            "/home/mrchou/code/cs231a"
          ]
        },
        {
          "paths": [
            "/home/mrchou/code/galaxy-network"
          ]
        }
      ],
      "nickname": "City7"
    }
  ],
  "ui_font_size": 20,
  "buffer_font_size": 18,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Tokyo Night"
  },
  "experimental.theme_overrides": {
    "created": "#85b304ff",
    "created.background": "#e9efd2ff",
    "created.border": "#d7e3aeff",
    "modified": "#f1ad49ff",
    "modified.background": "#ffeedaff",
    "modified.border": "#ffe1beff",
    "deleted": "#ef7177ff",
    "deleted.background": "#48161bff",
    "deleted.border": "#66272dff"
  },
  "project_panel": {
    "dock": "right",
    "default_width": 500
  },
  "jupyter": {
    "enabled": true,
    "kernel_selections": {"python": "jupyter-venv"}
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "format_on_save": "off",
  "terminal": {
    "dock": "right"
  }
}
